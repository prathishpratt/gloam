---
import type { CollectionEntry } from 'astro:content';
import SourceBadge from './SourceBadge.astro';
import TagBadge from './TagBadge.astro';
import { formatDate } from '../utils/posts';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, source_site, date_saved, tags, cover_image } = post.data;

// Show up to 3 tags
const displayTags = tags.slice(0, 3);
const postHref = `/posts/${post.slug}`;
---

<article class="post-card" data-tags={tags.join(',')} data-source={source_site}>
  <a href={postHref} class="post-card-link" tabindex="-1" aria-hidden="true"></a>

  {cover_image && (
    <div class="post-card-cover">
      <img
        src={cover_image}
        alt={title}
        loading="lazy"
        decoding="async"
        class="post-card-cover-img"
      />
    </div>
  )}

  <div class="post-card-body">
    <div class="post-card-meta">
      <SourceBadge source_site={source_site} link={false} />
      <time class="post-card-date" datetime={date_saved.toISOString()}>
        {formatDate(date_saved)}
      </time>
    </div>

    <h2 class="post-card-title">
      <a href={postHref} class="post-card-title-link">
        {title}
      </a>
    </h2>

    {description && (
      <p class="post-card-description">{description}</p>
    )}

    {displayTags.length > 0 && (
      <div class="post-card-tags">
        {displayTags.map((tag) => (
          <TagBadge tag={tag} size="sm" />
        ))}
        {tags.length > 3 && (
          <span class="post-card-tags-more">+{tags.length - 3}</span>
        )}
      </div>
    )}
  </div>
</article>

<style>
  .post-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base),
      border-color var(--transition-base);
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
  }

  /* Invisible full-card click target (behind content) */
  .post-card-link {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: var(--radius-lg);
  }

  .post-card-cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
  }

  .post-card-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-base);
  }

  .post-card:hover .post-card-cover-img {
    transform: scale(1.03);
  }

  .post-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .post-card-date {
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    margin-left: auto;
  }

  .post-card-title {
    font-size: var(--font-size-base);
    font-weight: 600;
    line-height: var(--line-height-tight);
    margin: 0;
  }

  @media (min-width: 640px) {
    .post-card-title {
      font-size: var(--font-size-lg);
    }
  }

  .post-card-title-link {
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    z-index: 2;
    transition: color var(--transition-fast);
  }

  .post-card-title-link::after {
    content: '';
    position: absolute;
    inset: -2px -4px;
    border-radius: var(--radius-sm);
  }

  .post-card:hover .post-card-title-link {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-card-title-link:visited {
    color: var(--color-text);
  }

  .post-card-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: var(--line-height-normal);
    /* 2-line clamp */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-2);
    position: relative;
    z-index: 2;
  }

  .post-card-tags-more {
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    padding: 0.2em 0.5em;
    background-color: var(--color-bg-subtle);
    border-radius: var(--radius-full);
  }
</style>
