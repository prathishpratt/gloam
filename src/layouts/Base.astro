---
interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = 'A personal reading archive — curated articles, essays, and posts worth keeping.',
  image = '/og-default.png',
  canonicalUrl,
} = Astro.props;

const siteUrl = 'https://gloam.prathish.dev';
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Prevent flash of wrong theme — must run before CSS renders -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('gloam-theme');
        var theme =
          stored ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <title>{title} — Gloam</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} — Gloam`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Gloam" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — Gloam`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Gloam RSS Feed"
      href="/rss.xml"
    />

  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
